# name: test/sql/local/catalog_test_config_setup/catalog_agnostic/test_tpch.test
# description: test integration with iceberg catalog read
# group: [catalog_agnostic]

require-env CATALOG_TEST_CONFIG_SETUP

require avro

require parquet

require iceberg

require httpfs

require tpch

# Do not ignore 'HTTP' error messages!
set ignore_error_messages

statement ok
create view customer as select * from my_datalake.default.customer;

statement ok
create view lineitem as select * from my_datalake.default.lineitem;

statement ok
create view nation as select * from my_datalake.default.nation;

statement ok
create view orders as select * from my_datalake.default.orders;

statement ok
create view part as select * from my_datalake.default.part;

statement ok
create view partsupp as select * from my_datalake.default.partsupp;

statement ok
create view region as select * from my_datalake.default.region;

statement ok
create view supplier as select * from my_datalake.default.supplier;

foreach disabled_optimizer 'filter_pushdown' ''

statement ok
pragma disabled_optimizers={disabled_optimizer};

query II rowsort expected_res
WITH revenue AS (
    SELECT
        l_suppkey AS supplier_no,
        sum(l_extendedprice * (1 - l_discount)) AS total_revenue
    FROM
        lineitem
    WHERE
        l_shipdate >= CAST('1996-01-01' AS date) AND l_shipdate < CAST('1996-04-01' AS date)
    GROUP BY
        supplier_no
)
FROM revenue;
----

endloop

mode skip

query I
WITH revenue AS (
    SELECT
        l_suppkey AS supplier_no,
        sum(l_extendedprice * (1 - l_discount)) AS total_revenue
    FROM
        lineitem
    WHERE
        l_shipdate >= CAST('1996-01-01' AS date)
      AND l_shipdate < CAST('1996-04-01' AS date)
    GROUP BY
        supplier_no
)
SELECT
    s_suppkey,
    s_name,
    s_address,
    s_phone,
    total_revenue
FROM
    supplier,
    revenue
WHERE
    s_suppkey = supplier_no
    AND total_revenue = (
        SELECT
            max(total_revenue)
        FROM revenue)
ORDER BY
    s_suppkey;
----
<FILE>:{WORKING_DIRECTORY}/duckdb/extension/tpch/dbgen/answers/sf1/q15.csv

mode skip

loop i 1 9

query I
PRAGMA tpch({i})
----
<FILE>:{WORKING_DIRECTORY}/duckdb/extension/tpch/dbgen/answers/sf1/q0{i}.csv

endloop

loop i 10 23

query I
PRAGMA tpch({i})
